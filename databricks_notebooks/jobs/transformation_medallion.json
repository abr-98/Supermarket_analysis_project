{
  "name": "Olist_Medallion_processing",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "timeout_seconds": 0,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Bronze_customer_processing",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Raw_to_Bronze_Olist_customer_dataset",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Bronze_order_items_and_sellers",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Raw_to_Bronze_order_item_and_sellers",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Bronze_order_payments_and_reviews",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Raw_to_bronze_order_payments_and_reviews_dataset",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Bronze_orders_processing",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Raw_to_Bronze_orders_dataset",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Bronze_products_processing",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Raw_to_Bronze_products_dataset",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Silver_customer_processing",
      "depends_on": [
        {
          "task_key": "Bronze_customer_processing"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Customer_silver_processing",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Silver_order_item_processing",
      "depends_on": [
        {
          "task_key": "Bronze_order_items_and_sellers"
        },
        {
          "task_key": "Bronze_products_processing"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Order_item_silver_processing",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false
    },
    {
      "task_key": "Silver_order_processing",
      "depends_on": [
        {
          "task_key": "Bronze_orders_processing"
        },
        {
          "task_key": "Bronze_order_payments_and_reviews"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Order_silver_processing",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "disabled": false
    }
  ],
  "queue": {
    "enabled": true
  },
  "performance_target": "PERFORMANCE_OPTIMIZED"
}